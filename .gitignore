# Terraform state files
*.tfstate
*.tfstate.*

# Terraform directory
*.terraform/

# Terraform lock file (optional: usually commit this in teams)
# .terraform.lock.hcl

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Crash logs
crash.log

# Sensitive override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH / infra keys only
*.pem
*.key
**-key.pem
**-key.pub
**-key